# CavBot production template (placeholders only)
# Server-only values must never be exposed to client bundles.

# Required core URLs
CAVBOT_APP_ORIGIN=https://app.cavbot.io
APP_URL=https://app.cavbot.io
NEXT_PUBLIC_APP_ORIGIN=https://app.cavbot.io
NEXT_PUBLIC_APP_URL=https://app.cavbot.io

# Required runtime + auth (server-only)
DATABASE_URL=paste_your_base_url_here
CAVBOT_SESSION_SECRET=paste_your_secret_here
CAVBOT_KEY_ENC_SECRET=paste_your_secret_here
CAVCLOUD_TOKEN_SECRET=paste_your_secret_here
CAVBOT_EMBED_TOKEN_SECRET=paste_your_secret_here
CAVBOT_VERIFY_SECRET=paste_your_secret_here
CAVBOT_INTEGRATIONS_TOKEN_ENC_SECRET=paste_your_secret_here

# Required provider credentials (server-only)
DEEPSEEK_API_KEY=paste_your_key_here
# or configure your Alibaba/Qwen provider keys instead:
ALIBABA_QWEN_BASE_URL=paste_your_base_url_here
ALIBABA_QWEN_FLASH_MODEL=paste_your_key_here
ALIBABA_QWEN_PLUS_MODEL=paste_your_key_here
ALIBABA_QWEN_MAX_MODEL=paste_your_key_here
ALIBABA_QWEN_CODER_MODEL=paste_your_key_here

# Required storage (server-only)
CAVCLOUD_R2_ENDPOINT=paste_your_base_url_here
CAVCLOUD_R2_ACCESS_KEY_ID=paste_your_key_here
CAVCLOUD_R2_SECRET_ACCESS_KEY=paste_your_secret_here
CAVCLOUD_R2_BUCKET=paste_your_key_here
CAVCLOUD_R2_REGION=paste_your_key_here
CAVCLOUD_GATEWAY_ORIGIN=paste_your_public_url_here

# Required billing
STRIPE_SECRET_KEY=paste_your_secret_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=paste_your_key_here
STRIPE_PRICE_PREMIUM_MONTHLY=paste_your_key_here
STRIPE_PRICE_PREMIUM_ANNUAL=paste_your_key_here
STRIPE_PRICE_PREMIUM_PLUS_MONTHLY=paste_your_key_here
STRIPE_PRICE_PREMIUM_PLUS_ANNUAL=paste_your_key_here

# Email
RESEND_API_KEY=paste_your_key_here
CAVBOT_MAIL_FROM=paste_your_public_url_here

# Public-safe runtime endpoints
NEXT_PUBLIC_WIDGET_CONFIG_ORIGIN=paste_your_public_url_here
NEXT_PUBLIC_EMBED_API_URL=paste_your_public_url_here
CAVBOT_CDN_BASE_URL=paste_your_public_url_here
NEXT_PUBLIC_CAVBOT_CDN_BASE_URL=paste_your_public_url_here
NEXT_PUBLIC_CAVBOT_RUNTIME_BOOT=paste_your_key_here
NEXT_PUBLIC_CAVBOT_LIVE_MODE=paste_your_key_here
