  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
}

enum ScanFindingSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum GeoCaptureLevel {
  OFF
  COUNTRY
  SUBDIVISION
}

enum BillingCycle {
  monthly
  annual
}

enum ServiceStatusState {
  HEALTHY
  AT_RISK
  INCIDENT
  UNKNOWN
}

enum IncidentStatus {
  INVESTIGATING
  IDENTIFIED
  MONITORING
  RESOLVED
}

enum IncidentImpact {
  MINOR
  MAJOR
  CRITICAL
}

model ServiceStatus {
  id                  String             @id @default(cuid())
  serviceKey          String             @unique
  displayName         String
  status              ServiceStatusState @default(UNKNOWN)
  lastCheckedAt       DateTime?
  lastSuccessAt       DateTime?
  lastLatencyMs       Int?
  errorMessage        String?
  consecutiveFailures Int                @default(0)
  region              String             @default("global")
  metaJson            Json?
  updatedAt           DateTime           @updatedAt

  history ServiceStatusHistory[]

  @@index([status])
  @@index([serviceKey])
}

model ServiceStatusHistory {
  id              String             @id @default(cuid())
  serviceStatusId String
  serviceKey      String
  status          ServiceStatusState
  latencyMs       Int?
  errorMessage    String?
  checkedAt       DateTime           @default(now())
  region          String             @default("global")
  metaJson        Json?

  serviceStatus ServiceStatus @relation(fields: [serviceStatusId], references: [id], onDelete: Cascade)

  @@index([serviceKey, checkedAt])
}

model StatusService {
  id        String   @id @default(cuid())
  slug      String   @unique
  label     String
  createdAt DateTime @default(now())

  samples StatusSample[]

  @@index([slug])
}

model StatusSample {
  id         String             @id @default(cuid())
  serviceId  String
  dayKey     String             @db.VarChar(10)
  status     ServiceStatusState
  message    String?
  incidentId String?
  component  String?
  durationMs Int?
  occurredAt DateTime           @default(now())
  createdAt  DateTime           @default(now())

  service StatusService @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId, dayKey])
  @@index([occurredAt])
}

model Incident {
  id                   String           @id @default(cuid())
  title                String
  status               IncidentStatus   @default(INVESTIGATING)
  impact               IncidentImpact   @default(MINOR)
  body                 String?
  affectedServices     String[]
  affectedServicesJson Json?
  startedAt            DateTime         @default(now())
  resolvedAt           DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  updates              IncidentUpdate[]
}

model IncidentUpdate {
  id         String         @id @default(cuid())
  incidentId String
  status     IncidentStatus
  message    String
  createdAt  DateTime       @default(now())

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId])
}
