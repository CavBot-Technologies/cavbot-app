generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  username             String?   @unique @db.VarChar(40)
  usernameChangeCount  Int       @default(0)
  lastUsernameChangeAt DateTime?
  displayName          String?

  fullName              String? @db.VarChar(140)
  bio                   String? @db.VarChar(300)
  country               String? @db.VarChar(80)
  region                String? @db.VarChar(80)
  timeZone              String? @db.VarChar(64)
  companyName           String? @db.VarChar(140)
  companyCategory       String? @db.VarChar(80)
  companySubcategory    String? @db.VarChar(80)
  githubUrl             String? @db.VarChar(200)
  instagramUrl          String? @db.VarChar(200)
  linkedinUrl           String? @db.VarChar(200)
  customLinkUrl         String? @db.Text
  showCavbotProfileLink Boolean @default(false)

  // Public CavBot Profile (privacy-first; OFF by default)
  publicProfileEnabled        Boolean @default(false)
  publicShowReadme            Boolean @default(true)
  publicShowWorkspaceSnapshot Boolean @default(false)
  publicShowHealthOverview    Boolean @default(false)
  publicShowCapabilities      Boolean @default(false)
  publicShowArtifacts         Boolean @default(false)
  publicShowPlanTier          Boolean @default(false)
  publicShowBio               Boolean @default(true)
  publicShowIdentityLinks     Boolean @default(false)
  publicShowIdentityLocation  Boolean @default(false)
  publicShowIdentityEmail     Boolean @default(false)
  // Stores the selected "workspace/project" to showcase publicly.
  // V1 stores the Project.id as a string to keep this field stable across future workspace abstractions.
  publicWorkspaceId           String? @db.VarChar(24)

  // Public profile "work mode" (privacy-first; OFF by default). Not social status.
  publicStatusEnabled   Boolean   @default(false)
  publicStatusMode      String?   @db.VarChar(24)
  publicStatusNote      String?   @db.VarChar(64)
  publicStatusUpdatedAt DateTime?

  // User presence status (privacy-first; OFF by default). User-controlled intent/presence only (not system health).
  showStatusOnPublicProfile Boolean   @default(false)
  userStatus                String?   @db.VarChar(24)
  userStatusNote            String?   @db.VarChar(64)
  userStatusUpdatedAt       DateTime?

  avatarTone  String? @db.VarChar(24)
  avatarImage String? @db.Text

  emailVerifiedAt DateTime?
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  auditEvents                    AuditLog[]              @relation("AuditOperator")
  authTokens                     AuthToken[]
  invitesSent                    Invite[]                @relation("InvitesSent")
  invitesReceived                Invite[]                @relation("InvitesReceived")
  memberships                    Membership[]
  auth                           UserAuth?
  oauthIdentities                OAuthIdentity[]
  integrationCredentials         IntegrationCredential[]
  siteDeletionActions            SiteDeletion[]          @relation("SiteDeletionOperator")
  usernameHistories              UsernameHistory[]
  usernameTombstones             UsernameTombstone[]
  usernameHistoryOperatorEntries UsernameHistory[]       @relation("UsernameHistoryOperator")

  notifications                   Notification[]
  notificationSettings            NotificationSettings[]
  publicArtifacts                 PublicArtifact[]
  publicProfileReadme             PublicProfileReadme?
  cavcloudShares                  CavCloudShare[]               @relation("CavCloudShareCreator")
  cavcloudStorageSharesCreated    CavCloudStorageShare[]        @relation("CavCloudStorageShareCreator")
  cavcloudSettings                CavCloudSettings[]
  cavsafeSettings                 CavSafeSettings[]
  cavcloudActivities              CavCloudActivity[]            @relation("CavCloudActivityOperator")
  cavcloudOperationLogs           CavCloudOperationLog[]        @relation("CavCloudOperationLogOperator")
  cavcloudFileAccesses            CavCloudFileAccess[]          @relation("CavCloudFileAccessUser")
  cavcloudFileAccessesGranted     CavCloudFileAccess[]          @relation("CavCloudFileAccessGrantor")
  cavcloudFolderAccesses          CavCloudFolderAccess[]        @relation("CavCloudFolderAccessUser")
  cavcloudFolderAccessesGranted   CavCloudFolderAccess[]        @relation("CavCloudFolderAccessGrantor")
  cavcodeProjectAccesses          CavCodeProjectAccess[]        @relation("CavCodeProjectAccessUser")
  cavcodeProjectAccessesGranted   CavCodeProjectAccess[]        @relation("CavCodeProjectAccessGrantor")
  cavcloudFileVersionsCreated     CavCloudFileVersion[]         @relation("CavCloudFileVersionCreator")
  cavcloudShortcuts               CavCloudShortcut[]
  cavcollabAccessRequests         CavCollabAccessRequest[]      @relation("CavCollabAccessRequestRequester")
  cavcollabAccessRequestsResolved CavCollabAccessRequest[]      @relation("CavCollabAccessRequestResolver")
  cavContributorLinks             CavContributorLink[]          @relation("CavContributorLinkCreator")
  cavcloudMultipartUploads        CavCloudMultipartUpload[]     @relation("CavCloudMultipartCreator")
  cavcloudFolderUploadSessions    CavCloudFolderUploadSession[] @relation("CavCloudFolderUploadSessionCreator")
  cavcloudImportSessions          CavCloudImportSession[]
  cavsafeSharesCreated            CavSafeShare[]                @relation("CavSafeShareCreator")
  cavsafeSharesReceived           CavSafeShare[]                @relation("CavSafeShareTarget")
  cavsafeAclsCreated              CavSafeAcl[]                  @relation("CavSafeAclCreatedBy")
  cavsafeAclsRevoked              CavSafeAcl[]                  @relation("CavSafeAclRevokedBy")
  cavsafeInvitesSent              CavSafeInvite[]               @relation("CavSafeInviteInviter")
  cavsafeInvitesReceived          CavSafeInvite[]               @relation("CavSafeInviteInvitee")
  cavsafeActivities               CavSafeActivity[]             @relation("CavSafeActivityOperator")
  cavsafeOperationLogs            CavSafeOperationLog[]         @relation("CavSafeOperationLogOperator")
  cavsafeSnapshots                CavSafeSnapshot[]             @relation("CavSafeSnapshotOperator")
  cavsafeMultipartUploads         CavSafeMultipartUpload[]      @relation("CavSafeMultipartCreator")
  cavpadNotesOwned                CavPadNote[]                  @relation("CavPadNoteOwner")
  cavpadNoteAccesses              CavPadNoteAccess[]            @relation("CavPadNoteAccessUser")
  cavpadNoteAccessesGranted       CavPadNoteAccess[]            @relation("CavPadNoteAccessGrantor")
  cavpadDirectoryAccesses         CavPadDirectoryAccess[]       @relation("CavPadDirectoryAccessUser")
  cavpadDirectoryAccessesGranted  CavPadDirectoryAccess[]       @relation("CavPadDirectoryAccessGrantor")
  cavpadNoteVersionsCreated       CavPadNoteVersion[]           @relation("CavPadNoteVersionAuthor")
  cavpadSettings                  CavPadSettings[]
  workspaceAccessRequests         WorkspaceAccessRequest[]      @relation("WorkspaceAccessRequester")
  workspaceAccessRequestsResolved WorkspaceAccessRequest[]      @relation("WorkspaceAccessResolver")
  coderCreditWallets             CoderCreditWallet[]
  coderCreditLedgerEntries       CoderCreditLedger[]
  coderUsageSnapshots            CoderUsageSnapshot[]
  coderPlanEvents                CoderPlanEvent[]
  coderContextSnapshots          CoderContextSnapshot[]

  @@index([createdAt])
  @@index([lastLoginAt])
  @@index([emailVerifiedAt])
}

enum PublicArtifactVisibility {
  PRIVATE
  LINK_ONLY
  PUBLIC_PROFILE
}

enum CavCloudShareMode {
  READ_ONLY
}

enum CavCloudAccessPermission {
  VIEW
  EDIT
}

enum CavCloudFolderAccessRole {
  VIEWER
  EDITOR
}

enum CavCodeProjectAccessRole {
  VIEWER
  EDITOR
  ADMIN
}

enum CavCollabResourceType {
  FILE
  FOLDER
  PROJECT
}

enum CavCollabRequestStatus {
  PENDING
  APPROVED
  DENIED
}

enum CavContributorPermission {
  EDIT
}

enum CavCloudOperationKind {
  CREATE_FOLDER
  UPLOAD_FILE
  MOVE_FILE
  RENAME_FILE
  DELETE_FILE
  RESTORE_FILE
  SHARE_CREATED
  SHARE_REVOKED
  DUPLICATE_FILE
  ZIP_CREATED
  PUBLISHED_ARTIFACT
  UNPUBLISHED_ARTIFACT
  COLLAB_ACCESS_GRANTED
  COLLAB_ACCESS_REVOKED
  COLLAB_REQUEST_CREATED
  COLLAB_REQUEST_APPROVED
  COLLAB_REQUEST_DENIED
  FILE_EDIT_SAVED
  FILE_EDIT_CONFLICT
  FILE_EDIT_DENIED
  CONTRIBUTOR_LINK_CREATED
  CONTRIBUTOR_LINK_USED
  CONTRIBUTOR_LINK_DENIED
  GOOGLE_DRIVE_CONNECTED
  GOOGLE_DRIVE_DISCONNECTED
  GOOGLE_DRIVE_IMPORT_STARTED
  GOOGLE_DRIVE_IMPORT_COMPLETED
  GOOGLE_DRIVE_IMPORT_FILE_FAILED
  FILE_UPLOADED
  FILE_RENAMED
  FILE_DELETED
  FOLDER_MOVED
  ARTIFACT_PUBLISHED
  COLLAB_GRANTED
  COLLAB_REVOKED
  ACCESS_GRANTED
  ACCESS_REVOKED
  FILE_OPENED
  FILE_DOWNLOADED
  EDIT_SAVED
  EDIT_CONFLICT
  FAILED_EDIT_ATTEMPT
}

enum CavSafeOperationKind {
  CREATE_FOLDER
  UPLOAD_FILE
  MOVE
  RENAME
  DELETE
  RESTORE
  MOVE_IN
  MOVE_OUT
  PUBLISH_ARTIFACT
  ACCESS_ATTEMPT
  OPEN_DENIED
  SHARE_ATTEMPT
  IMMUTABLE_SET
  IMMUTABLE_CLEAR
  TIMELOCK_SET
  TIMELOCK_CLEAR
  SNAPSHOT_CREATED
}

enum CavSafeAclPrincipalType {
  USER
  WORKSPACE
}

enum CavSafeAclRole {
  OWNER
  EDITOR
  VIEWER
}

enum CavSafeAclStatus {
  ACTIVE
  REVOKED
}

enum CavSafeInviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum CavCloudMountMode {
  READ_ONLY
  READ_WRITE
}

enum CavCloudShortcutTargetType {
  FILE
  FOLDER
}

enum IntegrationProvider {
  GOOGLE_DRIVE
}

enum CavCloudImportSessionStatus {
  CREATED
  RUNNING
  COMPLETED
  FAILED
  CANCELED
}

enum CavCloudImportItemKind {
  FILE
  FOLDER
}

enum CavCloudImportItemStatus {
  PENDING
  IMPORTING
  IMPORTED
  FAILED
}

// Explicitly published public items (never auto-exposed).
// V1 supports listing; publishing controls come later.
model PublicArtifact {
  id           String                   @id @default(cuid())
  userId       String
  // Public-facing title. Never render internal file paths on public pages.
  displayTitle String                   @map("title") @db.VarChar(140)
  type         String                   @db.VarChar(32)
  // CavCloud object key relative to the gateway contract (Worker expects /cavcloud/{objectKey}).
  storageKey   String                   @default("") @db.Text
  mimeType     String                   @default("application/octet-stream") @db.VarChar(200)
  sizeBytes    Int                      @default(0)
  sha256       String?                  @db.VarChar(64)
  visibility   PublicArtifactVisibility @default(PRIVATE)
  publishedAt  DateTime?
  expiresAt    DateTime?
  // Internal mapping back to the CavCloud UI selection (never exposed publicly).
  // Nullable to allow legacy rows to exist without blocking migrations.
  sourcePath   String?                  @db.Text
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  shares CavCloudShare[]

  @@unique([userId, sourcePath])
  @@index([userId])
  @@index([publishedAt])
  @@index([expiresAt])
  @@index([visibility])
  @@index([userId, visibility, publishedAt])
}

model CavCloudShare {
  id              String            @id @default(cuid())
  accountId       String?
  artifactId      String
  createdByUserId String
  mode            CavCloudShareMode @default(READ_ONLY)
  accessPolicy    String            @default("anyone") @db.VarChar(32)
  expiresAt       DateTime
  revokedAt       DateTime?
  createdAt       DateTime          @default(now())

  account       Account?       @relation(fields: [accountId], references: [id], onDelete: SetNull)
  artifact      PublicArtifact @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  createdByUser User           @relation("CavCloudShareCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([artifactId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@index([createdByUserId])
  @@index([artifactId, expiresAt])
}

enum CavCloudMultipartStatus {
  CREATED
  COMPLETED
  ABORTED
  EXPIRED
}

enum CavCloudFolderUploadSessionStatus {
  CREATED
  UPLOADING
  COMPLETE
  FAILED
}

enum CavCloudFolderUploadSessionFileStatus {
  CREATED
  UPLOADING
  READY
  FAILED
}

enum CavCloudFileStatus {
  UPLOADING
  READY
  FAILED
}

model CavCloudFolder {
  id          String    @id @default(cuid())
  accountId   String
  workspaceId String?
  parentId    String?
  name        String    @db.VarChar(220)
  path        String    @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  account                      Account                           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  parent                       CavCloudFolder?                   @relation("CavCloudFolderParent", fields: [parentId], references: [id], onDelete: SetNull)
  children                     CavCloudFolder[]                  @relation("CavCloudFolderParent")
  files                        CavCloudFile[]
  accessGrants                 CavCloudFolderAccess[]
  trashEntries                 CavCloudTrash[]                   @relation("CavCloudTrashFolder")
  shares                       CavCloudStorageShare[]
  filePathIndexes              CavCloudFilePathIndex[]
  projectMounts                CavCodeProjectMount[]
  multipartUploads             CavCloudMultipartUpload[]
  folderUploadSessionsAsParent CavCloudFolderUploadSession[]     @relation("CavCloudFolderUploadSessionParent")
  folderUploadSessionsAsRoot   CavCloudFolderUploadSession[]     @relation("CavCloudFolderUploadSessionRoot")
  folderUploadSessionFiles     CavCloudFolderUploadSessionFile[] @relation("CavCloudFolderUploadSessionFileFolder")
  importSessionsAsTarget       CavCloudImportSession[]           @relation("CavCloudImportSessionTargetFolder")

  @@unique([accountId, path])
  @@unique([accountId, parentId, name])
  @@index([accountId, parentId])
  @@index([accountId, deletedAt])
  @@index([accountId, path])
}

model CavCloudFile {
  id                      String             @id @default(cuid())
  accountId               String
  workspaceId             String?
  folderId                String
  name                    String             @db.VarChar(220)
  path                    String             @db.Text
  relPath                 String             @default("") @db.Text
  r2Key                   String             @db.Text
  bytes                   BigInt             @default(0)
  mimeType                String             @db.VarChar(200)
  sha256                  String             @db.VarChar(64)
  previewSnippet          String?            @db.Text
  previewSnippetUpdatedAt DateTime?
  status                  CavCloudFileStatus @default(READY)
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  deletedAt               DateTime?

  account                  Account                           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  folder                   CavCloudFolder                    @relation(fields: [folderId], references: [id], onDelete: Restrict)
  accessGrants             CavCloudFileAccess[]
  versions                 CavCloudFileVersion[]
  trashEntries             CavCloudTrash[]                   @relation("CavCloudTrashFile")
  shares                   CavCloudStorageShare[]
  pathIndexes              CavCloudFilePathIndex[]
  multipartUploads         CavCloudMultipartUpload[]         @relation("CavCloudMultipartCompletedFile")
  folderUploadSessionFiles CavCloudFolderUploadSessionFile[]
  importItems              CavCloudImportItem[]
  cavpadNotes              CavPadNote[]

  @@unique([accountId, path])
  @@unique([accountId, folderId, name])
  @@index([accountId, folderId])
  @@index([accountId, deletedAt])
  @@index([accountId, path])
  @@index([accountId, relPath])
  @@index([accountId, status])
}

model CavPadDirectory {
  id        String    @id @default(cuid())
  accountId String
  name      String    @db.VarChar(80)
  parentId  String?
  pinnedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  account      Account                 @relation(fields: [accountId], references: [id], onDelete: Cascade)
  parent       CavPadDirectory?        @relation("CavPadDirectoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children     CavPadDirectory[]       @relation("CavPadDirectoryTree")
  notes        CavPadNote[]
  accessGrants CavPadDirectoryAccess[]
  noteVersions CavPadNoteVersion[]

  @@unique([accountId, parentId, name], name: "cavpad_directory_sibling_name_unique")
  @@index([accountId, parentId])
  @@index([accountId, pinnedAt])
  @@index([accountId, updatedAt])
}

model CavPadNote {
  id             String    @id @default(cuid())
  accountId      String
  ownerUserId    String
  cavcloudFileId String?
  textContent    String    @default("") @db.Text
  title          String    @db.VarChar(160)
  directoryId    String?
  pinnedAt       DateTime?
  scope          String    @default("workspace") @db.VarChar(16)
  siteId         String?   @db.VarChar(120)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  trashedAt      DateTime?
  expiresAt      DateTime?

  account       Account             @relation(fields: [accountId], references: [id], onDelete: Cascade)
  ownerUser     User                @relation("CavPadNoteOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  cavcloudFile  CavCloudFile?       @relation(fields: [cavcloudFileId], references: [id], onDelete: SetNull)
  directory     CavPadDirectory?    @relation(fields: [directoryId], references: [id], onDelete: SetNull)
  accessGrants  CavPadNoteAccess[]
  localVersions CavPadNoteVersion[]

  @@unique([accountId, cavcloudFileId], name: "cavpad_note_file_unique")
  @@index([accountId, pinnedAt])
  @@index([accountId, updatedAt])
  @@index([accountId, trashedAt])
  @@index([accountId, directoryId])
  @@index([accountId, ownerUserId])
}

model CavPadNoteAccess {
  id              String                   @id @default(cuid())
  accountId       String
  noteId          String
  userId          String
  permission      CavCloudAccessPermission @default(VIEW)
  expiresAt       DateTime?
  grantedByUserId String
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  account       Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  note          CavPadNote @relation(fields: [noteId], references: [id], onDelete: Cascade)
  user          User       @relation("CavPadNoteAccessUser", fields: [userId], references: [id], onDelete: Cascade)
  grantedByUser User       @relation("CavPadNoteAccessGrantor", fields: [grantedByUserId], references: [id], onDelete: Cascade)

  @@unique([accountId, noteId, userId], name: "cavpad_note_access_unique")
  @@index([accountId, noteId])
  @@index([accountId, userId])
  @@index([accountId, expiresAt])
}

model CavPadDirectoryAccess {
  id              String                   @id @default(cuid())
  accountId       String
  directoryId     String
  userId          String
  permission      CavCloudAccessPermission @default(VIEW)
  expiresAt       DateTime?
  grantedByUserId String
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  account       Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  directory     CavPadDirectory @relation(fields: [directoryId], references: [id], onDelete: Cascade)
  user          User            @relation("CavPadDirectoryAccessUser", fields: [userId], references: [id], onDelete: Cascade)
  grantedByUser User            @relation("CavPadDirectoryAccessGrantor", fields: [grantedByUserId], references: [id], onDelete: Cascade)

  @@unique([accountId, directoryId, userId], name: "cavpad_directory_access_unique")
  @@index([accountId, directoryId])
  @@index([accountId, userId])
  @@index([accountId, expiresAt])
}

model CavPadNoteVersion {
  id              String   @id
  accountId       String
  noteId          String
  versionNumber   Int
  sha256          String   @db.VarChar(64)
  title           String   @db.VarChar(160)
  textContent     String   @default("") @db.Text
  directoryId     String?
  createdByUserId String?
  createdAt       DateTime @default(now())

  account       Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  note          CavPadNote       @relation(fields: [noteId], references: [id], onDelete: Cascade)
  directory     CavPadDirectory? @relation(fields: [directoryId], references: [id], onDelete: SetNull)
  createdByUser User?            @relation("CavPadNoteVersionAuthor", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@unique([accountId, noteId, versionNumber], name: "cavpad_note_version_unique")
  @@index([accountId, noteId, createdAt])
  @@index([accountId, noteId, versionNumber])
}

model CavPadSettings {
  id                     String                   @id @default(cuid())
  accountId              String
  userId                 String
  syncToCavcloud         Boolean                  @default(false)
  syncToCavsafe          Boolean                  @default(false)
  allowSharing           Boolean                  @default(true)
  defaultSharePermission CavCloudAccessPermission @default(VIEW)
  defaultShareExpiryDays Int                      @default(0)
  noteExpiryDays         Int                      @default(0)
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([accountId, userId], name: "accountId_userId")
  @@index([accountId])
  @@index([userId])
}

model CavenSettings {
  accountId               String
  userId                  String
  queueFollowUps          Boolean  @default(true)
  composerEnterBehavior   String   @default("enter") @db.VarChar(24)
  includeIdeContext       Boolean  @default(true)
  confirmBeforeApplyPatch Boolean  @default(true)
  autoOpenResolvedFiles   Boolean  @default(true)
  showReasoningTimeline   Boolean  @default(true)
  telemetryOptIn          Boolean  @default(true)
  defaultReasoningLevel   String   @default("medium") @db.VarChar(24)
  asrAudioSkillEnabled    Boolean  @default(true)
  installedAgentIds       Json     @default("[]")
  customAgents            Json     @default("[]")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@id([accountId, userId])
  @@index([userId])
}

model CavCloudFileAccess {
  id              String                   @id @default(cuid())
  accountId       String
  fileId          String
  userId          String
  permission      CavCloudAccessPermission @default(VIEW)
  expiresAt       DateTime?
  grantedByUserId String
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  account       Account            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  file          CavCloudFile       @relation(fields: [fileId], references: [id], onDelete: Cascade)
  user          User               @relation("CavCloudFileAccessUser", fields: [userId], references: [id], onDelete: Cascade)
  grantedByUser User               @relation("CavCloudFileAccessGrantor", fields: [grantedByUserId], references: [id], onDelete: Cascade)
  shortcuts     CavCloudShortcut[]

  @@unique([accountId, fileId, userId])
  @@index([accountId, fileId])
  @@index([accountId, userId])
  @@index([accountId, expiresAt])
}

model CavCloudFolderAccess {
  id              String                   @id @default(cuid())
  accountId       String
  folderId        String
  userId          String
  role            CavCloudFolderAccessRole @default(VIEWER)
  expiresAt       DateTime?
  grantedByUserId String
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  account       Account            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  folder        CavCloudFolder     @relation(fields: [folderId], references: [id], onDelete: Cascade)
  user          User               @relation("CavCloudFolderAccessUser", fields: [userId], references: [id], onDelete: Cascade)
  grantedByUser User               @relation("CavCloudFolderAccessGrantor", fields: [grantedByUserId], references: [id], onDelete: Cascade)
  shortcuts     CavCloudShortcut[]

  @@unique([accountId, folderId, userId])
  @@index([accountId, folderId])
  @@index([accountId, userId])
  @@index([accountId, expiresAt])
}

model CavCloudFileVersion {
  id                    String   @id @default(cuid())
  accountId             String
  fileId                String
  versionNumber         Int
  sha256                String   @db.VarChar(64)
  r2Key                 String   @db.Text
  bytes                 BigInt   @default(0)
  createdByUserId       String
  restoredFromVersionId String?
  createdAt             DateTime @default(now())

  account       Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  file          CavCloudFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  createdByUser User         @relation("CavCloudFileVersionCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@unique([fileId, versionNumber])
  @@index([fileId, createdAt(sort: Desc)])
  @@index([accountId, fileId])
}

model CavCloudShortcut {
  id             String                     @id @default(cuid())
  accountId      String
  userId         String
  targetType     CavCloudShortcutTargetType
  targetId       String
  fileAccessId   String?
  folderAccessId String?
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt

  account      Account               @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileAccess   CavCloudFileAccess?   @relation(fields: [fileAccessId], references: [id], onDelete: SetNull)
  folderAccess CavCloudFolderAccess? @relation(fields: [folderAccessId], references: [id], onDelete: SetNull)

  @@unique([accountId, userId, targetType, targetId])
  @@index([accountId, userId])
  @@index([accountId, targetType, targetId])
  @@index([fileAccessId])
  @@index([folderAccessId])
}

model CavCloudTrash {
  id         String   @id @default(cuid())
  accountId  String
  fileId     String?
  folderId   String?
  deletedAt  DateTime @default(now())
  purgeAfter DateTime
