# Safe localhost overrides for `npm run dev`
# Copy this file to `.env.development.local` and replace placeholders.
# This file is loaded only in development.

# Force the app to behave like localhost instead of app.cavbot.io
CAVBOT_DEV_ORIGIN=http://localhost:3000
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
AUTH_REDIRECT_BASE_URL=http://localhost:3000
NEXT_PUBLIC_WIDGET_CONFIG_ORIGIN=http://localhost:3000
NEXT_PUBLIC_EMBED_API_URL=http://localhost:3000
NEXT_PUBLIC_CAVBOT_LIVE_MODE=0
NEXT_PUBLIC_CAVBOT_DISABLE_EVENTS=1

# Required for safe dev: point to a local Postgres instance.
# `npm run dev` now refuses to boot against a remote DB unless you explicitly opt in.
CAVBOT_DEV_DATABASE_URL=postgresql://cavbot:change_me@127.0.0.1:5432/cavbot
CAVBOT_DEV_DIRECT_URL=postgresql://cavbot:change_me@127.0.0.1:5432/cavbot

# Safety switches. Keep both at 0 unless you intentionally want remote services in dev.
CAVBOT_ALLOW_REMOTE_DEV_DB=0
CAVBOT_ALLOW_LIVE_INTEGRATIONS_IN_DEV=0

# Optional: Stripe test keys are allowed in safe dev mode.
# Other live integrations below stay stripped unless `CAVBOT_ALLOW_LIVE_INTEGRATIONS_IN_DEV=1`.
# STRIPE_SECRET_KEY=sk_test_xxx
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# RESEND_API_KEY=re_xxx
# RESEND_SIGNUP_API_KEY=re_xxx
# CAVCLOUD_R2_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# CAVCLOUD_R2_ACCESS_KEY_ID=xxx
# CAVCLOUD_R2_SECRET_ACCESS_KEY=xxx
# CAVCLOUD_R2_BUCKET=xxx
# CAVCLOUD_R2_REGION=auto
